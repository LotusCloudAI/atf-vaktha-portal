{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "lib": ["ES2022"],

    "rootDir": "src",
    "outDir": "lib",

    "sourceMap": true,

    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true
  },

  "compileOnSave": true,
  "include": ["src"],
  "exclude": ["node_modules", "lib"]
}