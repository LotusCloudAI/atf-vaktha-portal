rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MANDATORY ADMIN HELPER
     * Checks if the authenticated user has an 'admin' role.
     */
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    /**
     * USER PROFILES
     * Users can manage their own data; Admins have full access.
     */
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    /**
     * SPEECH ANALYTICS & PHASE 7 TRENDING
     * Results generated by your AI Backend.
     */
    match /speeches/{speechId} {
      // Allow any logged-in user to upload/trigger (create)
      allow create: if request.auth != null;
      
      // Allow users to see their own results or admins to see all
      // Phase 7 addition: allowing general read if authenticated for trending/feed purposes
      allow read: if request.auth != null;
      
      // Only admins or the backend can modify or delete processed results
      allow update, delete: if isAdmin();
    }

    /**
     * PHASE 7 — USER STATS
     * Read-only for users (updated by backend jobs).
     */
    match /userStats/{userId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    /**
     * PHASE 7 — LEADERBOARDS
     * Publicly readable, backend-only writable.
     */
    match /leaderboards/{docId} {
      allow read: if true;
      allow write: if false;
    }

    /**
     * GLOBAL APP DATA (PHASE 4 & 5)
     * Publicly readable, admin-only writable.
     */
    match /organizations/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /programs/{docId} { allow read: if true; allow write: if isAdmin(); }

    /**
     * DEFAULT DENY
     * Catch-all to ensure no data is exposed accidentally.
     */
    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}