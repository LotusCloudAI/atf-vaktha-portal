/**
 * MANDATORY ADMIN HELPER
 * Checks if the authenticated user has an 'admin' role.
 */
function isAdmin() {
  return request.auth != null &&
    get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
}

/**
 * USER PROFILES
 * Users can manage their own data; Admins have full access.
 */
match /users/{userId} {
  allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
}

/**
 * SPEECH ANALYTICS
 * Results generated by your AI Backend.
 */
match /speeches/{speechId} {
  // Allow any logged-in user to upload/trigger (create)
  allow create: if request.auth != null;
  
  // Allow users to see their own results or admins to see all
  allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
  
  // Only admins can modify or delete processed results
  allow update, delete: if isAdmin();
}

/**
 * GLOBAL APP DATA (PHASE 4 & 5)
 * Publicly readable, admin-only writable.
 */
match /organizations/{docId} { allow read: if true; allow write: if isAdmin(); }
match /programs/{docId} { allow read: if true; allow write: if isAdmin(); }
match /leaderboard/{docId} { allow read: if true; allow write: if isAdmin(); }

/**
 * DEFAULT DENY
 * Catch-all to ensure no data is exposed accidentally.
 */
match /{path=**} {
  allow read, write: if isAdmin();
}
