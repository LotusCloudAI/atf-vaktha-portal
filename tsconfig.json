{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,

    // 🔥 KEEP THESE FOR BUILD SUCCESS
    "skipLibCheck": true,
    "strict": false,

    "noEmit": true,
    "incremental": true,

    "module": "esnext",
    "esModuleInterop": true,

    // 🔥 IMPORTANT FOR NEXT 13/14/15+
    "moduleResolution": "bundler",

    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",

    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": ["node_modules"]
}